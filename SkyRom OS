<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SkyRom OS</title>

<style>

body{
margin:0;
font-family:Arial;
overflow:hidden;
background:black;
}

/* BOOT */

.boot{
display:flex;
align-items:center;
justify-content:center;
height:100vh;
font-size:40px;
color:white;
animation:boot 2s infinite alternate;
}

@keyframes boot{
from{opacity:.5}
to{opacity:1}
}

/* LOCK */

.lock{
display:none;
height:100vh;
background:url('tornado.gif') center/cover;
align-items:center;
justify-content:center;
color:white;
font-size:30px;
flex-direction:column;
}

/* DYNAMIC ISLAND */

.island{

position:fixed;
top:10px;
left:50%;
transform:translateX(-50%);
background:black;
color:white;
padding:10px 25px;
border-radius:30px;
font-size:14px;
display:none;
animation:island .5s;
}

@keyframes island{
from{transform:translateX(-50%) scale(.7);opacity:0}
to{transform:translateX(-50%) scale(1);opacity:1}
}

/* HOME */

.home{

display:none;
grid-template-columns:repeat(4,1fr);
gap:20px;
padding:40px;

}

.app{

background:rgba(255,255,255,.2);
color:white;
text-align:center;
padding:20px;
border-radius:20px;
backdrop-filter:blur(20px);
transition:transform .12s cubic-bezier(.2,.8,.2,1);
}

.app:active{
transform:scale(.85);
}

/* APP WINDOW */

.appWindow{

position:absolute;
top:0;
left:0;
width:100%;
height:100%;
background:white;
display:none;
justify-content:center;
align-items:center;
font-size:30px;

}

/* NOTIFICATION */

.notification{

position:fixed;
top:-100px;
left:50%;
transform:translateX(-50%);
background:white;
padding:15px 25px;
border-radius:20px;
box-shadow:0 10px 30px rgba(0,0,0,.3);
transition:.4s;

}

.show{
top:40px;
}

</style>

</head>

<body onload="boot()">

<div class="boot" id="boot">SkyRom OS</div>

<div class="lock" id="lock">
Tap to Unlock
</div>

<div class="island" id="island"></div>

<div class="notification" id="notification"></div>

<div class="home" id="home">

<div class="app" onclick="openApp('Calculator')">Calculator</div>
<div class="app" onclick="openApp('Settings')">Settings</div>
<div class="app" onclick="openApp('Notes')">Notes</div>
<div class="app" onclick="openApp('Weather')">Weather</div>
<div class="app" onclick="openApp('Camera')">Camera</div>
<div class="app" onclick="openApp('Themes')">Themes</div>
<div class="app" onclick="notify('New message')">Messages</div>
<div class="app" onclick="notify('Battery 90%')">Battery</div>

</div>

<div class="appWindow" id="appWindow">
<div id="appContent"></div>
</div>

<script>

/* BOOT */

function boot(){

setTimeout(()=>{

document.getElementById("boot").style.display="none"
document.getElementById("lock").style.display="flex"

},2500)

}

/* UNLOCK */

document.getElementById("lock").onclick=function(){

this.style.display="none"
document.getElementById("home").style.display="grid"

island("Phone Unlocked")

}

/* OPEN APP */

function openApp(name){

let win=document.getElementById("appWindow")
let content=document.getElementById("appContent")

content.innerHTML=name+" App"

win.style.display="flex"

win.style.transform="scale(.9)"
win.style.opacity="0"

requestAnimationFrame(()=>{

win.style.transition=".25s"
win.style.transform="scale(1)"
win.style.opacity="1"

})

}

/* SWIPE BACK */

let startX=0

document.addEventListener("touchstart",e=>{
startX=e.touches[0].clientX
})

document.addEventListener("touchend",e=>{

let endX=e.changedTouches[0].clientX

if(endX-startX>120){

document.getElementById("appWindow").style.display="none"

}

})

/* DYNAMIC ISLAND */

function island(text){

let island=document.getElementById("island")

island.innerText=text
island.style.display="block"

setTimeout(()=>{
island.style.display="none"
},2000)

}

/* NOTIFICATION */

function notify(text){

let n=document.getElementById("notification")

n.innerText=text

n.classList.add("show")

setTimeout(()=>{

n.classList.remove("show")

},3000)

}

</script>

</body>
</html>
